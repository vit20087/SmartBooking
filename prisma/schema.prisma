generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id           Int       @id @default(autoincrement())
  name         String
  email        String    @unique
  password     String
  role         String    @default("CLIENT")   // CLIENT | MASTER | ADMIN
  photoUrl     String?   @default("https://i.pravatar.cc/300")
  bio          String?   @default("Професійний майстер з 5+ роками досвіду")
  rating       Float     @default(0)
  reviewCount  Int       @default(0)
  createdAt    DateTime  @default(now())

  // Відносини
  services        Service[] @relation("MasterServices")
  bookings        Booking[]
  reviewsGiven    Review[]  @relation("Reviewer")
  reviewsReceived Review[]  @relation("MasterReviews")
}

model Service {
  id          Int       @id @default(autoincrement())
  name        String
  description String
  category    String    @default("Краса")
  price       Float
  durationMin Int
  imageUrl    String?
  masterId    Int

  master      User      @relation("MasterServices", fields: [masterId], references: [id])
  bookings    Booking[]

  createdAt   DateTime  @default(now())
}

model Booking {
  id        Int      @id @default(autoincrement())
  userId    Int
  serviceId Int
  date      DateTime
  status    String   @default("pending")  // pending | confirmed | completed | cancelled

  user      User     @relation(fields: [userId], references: [id])
  service   Service  @relation(fields: [serviceId], references: [id])
  review    Review?

  createdAt DateTime @default(now())
}

model Review {
  id        Int      @id @default(autoincrement())
  bookingId Int      @unique
  userId    Int
  masterId  Int
  rating    Int      // 1–5
  comment   String?
  createdAt DateTime @default(now())

  booking   Booking  @relation(fields: [bookingId], references: [id])
  user      User     @relation("Reviewer", fields: [userId], references: [id])
  master    User     @relation("MasterReviews", fields: [masterId], references: [id])
}
